    <resultMap type="ExpBaseDto" id="ExpEleResult">
        <id     property="expEleId"  column="exp_ele_id"      />
        <result property="expId"     column="exp_id"    />
        <result property="expCode"     column="exp_code"    />
        <result property="expName"     column="exp_name"    />
        <result property="catalogId"     column="catalog_id"    />
        <result property="catalogName"     column="catalog_name"    />
        <result property="catalogCode"     column="catalog_code"    />
        <result property="eleId"       column="ele_id"    />
        <result property="eleName"     column="ele_name"    />
        <result property="eleCode"     column="ele_code"    />
        <result property="eleType"     column="ele_type"    />
        <result property="eleValue"     column="ele_value"    />
        <result property="remark"      column="remark"    />
    </resultMap>

    <resultMap type="ExpAssetsDto" id="ExpAssResult">
        <id     property="expAssetsId"  column="exp_assets_id"      />
        <result property="assetsId"     column="assets_id"    />
        <result property="assetsName"     column="assets_name"    />
        <result property="assetsType"       column="assets_type"    />
        <result property="expAssetsNumber"  column="exp_assets_number"    />
        <result property="assetsCatalogId"    column="assets_catalog_id"    />
        <result property="assetsCatalogName"     column="assets_catalog_name" />
